@page "/"

<PageTitle>EventEase</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="p-5 bg-light rounded shadow-sm">
                <h1 class="display-5">Welcome to EventEase</h1>
                <p class="lead">A simple Blazor event management experience for GitHub Pages.</p>
                <p>
                    Create, update, delete, and browse your events from a clean single-page interface.
                    EventEase is designed to work with client-side routing and repository-hosted deployments.
                </p>
                <ul>
                    <li>List all events</li>
                    <li>Add new events</li>
                    <li>Edit existing events</li>
                    <li>Remove events you no longer need</li>
                </ul>
                <div class="mt-4">
                    <NavLink class="btn btn-primary btn-lg me-2" href="events">Manage Events</NavLink>
                    <NavLink class="btn btn-outline-secondary btn-lg" href="registration">Register</NavLink>
                </div>
            </div>
        </div>
    </div>
</div>
